# --- Python ---
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Environment variables ---
.env
.env.local
*/.env
!*/.env.example

# --- Node / React (frontend) ---
node_modules/
dist/
frontend/dist/
.vite/

# --- ML model artifacts ---
# The two selected final models (LogisticRegression + Ridge, ~7KB/~6KB) are
# committed on purpose -- the deployed backend (Render) loads them straight
# from the repo checkout at startup, so they have to actually be present in
# git, not just generated locally. Other/experimental *.pkl files (e.g. a
# candidate model saved during training that wasn't selected) stay ignored.
models/*.pkl
!models/classification_model.pkl
!models/regression_model.pkl
models/*.joblib
models/*.onnx
models/artifacts/*
!models/artifacts/.gitkeep

# --- Quarto (reports/slides) ---
/.quarto/
*_files/
*_cache/
_output/

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
.claude/settings.local.json
.playwright-mcp/

# --- Logs ---
*.log
